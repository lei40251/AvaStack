# 基础环境
# ENV: 运行环境标识，当前仓库默认使用 dev。
# LOG_LEVEL: 应用日志级别，常见值如 debug / info / warn / error。
ENV=dev
LOG_LEVEL=info

# 对外暴露到宿主机的端口
# 左侧是你本机访问时使用的端口，右侧容器内服务端口由 compose.yaml 维护。
# 如果本机端口冲突，通常只需要改这里。
ORCHESTRATOR_PORT=58080
ASR_PORT=58101
TTS_PORT=58102
AVATAR_PORT=58103
LLM_PORT=58104
ADMIN_PORT=54173
LIVEKIT_PORT=57880
LIVEKIT_TCP_PORT=57881
LIVEKIT_UDP_PORT=57882
SRS_RTMP_PORT=51935
SRS_API_PORT=51985
SRS_HTTP_PORT=58081

# 容器内服务间调用地址
# Docker Compose 模式下，默认使用服务名互相访问，一般不需要修改。
# 只有当你替换某个服务的部署位置，或希望接到外部已有服务时，才需要覆盖这些地址。
ASR_BASE_URL=http://avastack-asr:8101
TTS_BASE_URL=http://avastack-tts:8102
AVATAR_BASE_URL=http://avastack-avatar:8103
LLM_BASE_URL=http://avastack-llm:8104

# 实时音视频与推流基础设施地址
# LIVEKIT_WS_URL: 编排层连接 LiveKit 的 WebSocket 地址。
# SRS_RTC_BASE_URL: 编排层访问 SRS HTTP API 的地址。
# VLLM_BASE_URL: 预留给外部大模型推理服务的地址；当前仓库未默认在 compose 中启动 vLLM。
LIVEKIT_WS_URL=ws://livekit:7880
SRS_RTC_BASE_URL=http://srs:1985
VLLM_BASE_URL=http://vllm:8000

# 可选代理配置
# 当你所在网络拉取 Docker 镜像、安装依赖或访问外部模型服务需要代理时，再取消注释。
# 如果不需要代理，保持注释即可。
# HTTP_PROXY=http://192.168.9.108:4781
# HTTPS_PROXY=http://192.168.9.108:4781
