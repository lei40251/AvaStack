# 基础环境
ENV=dev
LOG_LEVEL=info

# 服务端口
ORCHESTRATOR_PORT=58080
ASR_PORT=58101
TTS_PORT=58102
AVATAR_PORT=58103
LLM_PORT=58104
ADMIN_PORT=54173
LIVEKIT_PORT=57880
LIVEKIT_TCP_PORT=57881
LIVEKIT_UDP_PORT=57882
SRS_RTMP_PORT=51935
SRS_API_PORT=51985
SRS_HTTP_PORT=58081

# 服务间访问地址
ASR_BASE_URL=http://avastack-asr:8101
TTS_BASE_URL=http://avastack-tts:8102
AVATAR_BASE_URL=http://avastack-avatar:8103
LLM_BASE_URL=http://avastack-llm:8104

# 基础设施地址
LIVEKIT_WS_URL=ws://livekit:7880
SRS_RTC_BASE_URL=http://srs:1985
VLLM_BASE_URL=http://vllm:8000

# 可选：如果本机网络访问外网需要代理，可在启动前按需设置
# HTTP_PROXY=http://192.168.9.108:4781
# HTTPS_PROXY=http://192.168.9.108:4781
